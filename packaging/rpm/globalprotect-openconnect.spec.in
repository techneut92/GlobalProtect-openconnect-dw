Name:           globalprotect-openconnect-dw
Version:        @VERSION@
Release:        @REVISION@
Summary:        GlobalProtect VPN backend (PKCS#11 fork) powered by OpenConnect
Group:          Productivity/Networking/PPP

License:        GPL-3.0
URL:            https://github.com/techneut92/GlobalProtect-openconnect-dw
Source:         @SOURCE@

BuildRequires:  make
BuildRequires:  libtool
BuildRequires:  autoconf
BuildRequires:  automake
BuildRequires:  gettext
BuildRequires:  gcc-c++
BuildRequires:  cargo
BuildRequires:  pkg-config
BuildRequires:  (openssl-devel or libopenssl-devel)
BuildRequires:  libxml2-devel
BuildRequires:  zlib-devel
BuildRequires:  (lz4-devel or liblz4-devel)
BuildRequires:  gnutls-devel
BuildRequires:  p11-kit-devel
BuildRequires:  (nettle-devel or libnettle-devel)
BuildRequires:  gmp-devel
BuildRequires:  wget
BuildRequires:  file
BuildRequires:  perl
# GUI (gpgui, Tauri) build dependencies — needed to build the -gui subpackage.
%if 0%{?suse_version}
BuildRequires:  webkit2gtk3-devel
%else
BuildRequires:  webkit2gtk4.1-devel
%endif
BuildRequires:  (libappindicator-gtk3-devel or libayatana-appindicator-gtk3-devel)
BuildRequires:  (librsvg2-devel or librsvg-devel)
BuildRequires:  libxdo-devel

# Runtime: openconnect tunnel + PKCS#11 / smart-card (YubiKey PIV) + polkit/D-Bus.
Requires:       openconnect
Requires:       opensc
Requires:       pcsc-lite
Requires:       polkit
Requires:       dbus
# gpauth is built with webview-auth (embedded SSO), so it links webkit.
%if 0%{?suse_version}
Requires:       webkit2gtk3
%else
Requires:       webkit2gtk4.1
%endif
Requires:       libsecret

# This package ships the same /usr/bin/gp* binaries as upstream.
Conflicts:      globalprotect-openconnect
Conflicts:      globalprotect-openconnect-snapshot

%global debug_package %{nil}

%description
The GlobalProtect VPN backend (PKCS#11 fork): the gpservice root daemon, gpauth
SAML helper, and gpclient CLI, based on OpenConnect. Supports SSO, smart-card /
PKCS#11 (YubiKey PIV), certificate, and password authentication. The graphical
client is packaged separately (the -gui subpackage, or a Flatpak).

%package gui
Summary:        GlobalProtect VPN graphical client (Tauri)
Requires:       %{name} = %{version}-%{release}
%if 0%{?suse_version}
Requires:       webkit2gtk3
%else
Requires:       webkit2gtk4.1
%endif
Requires:       libsecret
Conflicts:      globalprotect-openconnect

%description gui
The GlobalProtect VPN graphical client (gpgui), a Tauri front-end that drives
the gpservice backend over D-Bus. Requires the %{name} backend package.

%prep
%setup

%build
# The injected RUSTFLAGS could fail the build
unset RUSTFLAGS
make build INCLUDE_GUI=1

%install
%make_install INCLUDE_GUI=1

%files
%defattr(-,root,root)
%{_bindir}/gpclient
%{_bindir}/gpauth
%{_bindir}/gpservice
%{_libexecdir}/gpclient/vpnc-script
%{_libexecdir}/gpclient/hipreport.sh

%dir /usr/lib/NetworkManager
%dir /usr/lib/NetworkManager/dispatcher.d
%dir /usr/lib/NetworkManager/dispatcher.d/pre-down.d
/usr/lib/NetworkManager/dispatcher.d/pre-down.d/gpclient.down
/usr/lib/NetworkManager/dispatcher.d/gpclient-nm-hook

# D-Bus system service (the host backend a Flatpak/native GUI talks to) + polkit.
%{_datadir}/dbus-1/system-services/io.github.techneut92.GPService.service
%{_datadir}/dbus-1/system.d/io.github.techneut92.GPService.conf
%{_datadir}/polkit-1/rules.d/49-gpservice.rules
%{_datadir}/polkit-1/actions/io.github.techneut92.gpservice.policy

%dir %{_libexecdir}/gpclient

%files gui
%defattr(-,root,root)
%{_bindir}/gpgui
%{_datadir}/applications/gpgui.desktop
%{_datadir}/icons/hicolor/128x128/apps/gpgui.png

%changelog
* @DATE@ Dylan Westra <dylanwestra@gmail.com> - @VERSION@
- Backend-only fork with PKCS#11 / smart-card prelogin mTLS support
