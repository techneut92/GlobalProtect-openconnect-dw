# Maintainer: Dylan Westra <dylanwestra@gmail.com>

_pkgname=@PKG_NAME@
pkgbase=${_pkgname}
pkgname="${_pkgname}"
pkgver="@VERSION@"
pkgrel=@REVISION@
pkgdesc="GlobalProtect VPN (PKCS#11 fork), based on OpenConnect. Smart-card / SSO / certificate auth."
arch=('x86_64' 'aarch64')
url="https://github.com/techneut92/GlobalProtect-openconnect-dw"
license=('GPL3')
makedepends=('make' 'pkg-config' 'cargo' 'file' 'autoconf' 'automake' 'gettext' 'libtool' 'patch')

source=("${_pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

options=('!strip')

build() {
  cd "$_pkgname-$pkgver"

  # Must unset the CFLAGS, otherwise the build fails
  unset CFLAGS

  make build
}

package() {
  pkgdesc="GlobalProtect VPN backend (PKCS#11 fork) — gpservice/gpclient/gpauth. The graphical client (gp-client) ships separately as a Flatpak."
  depends=('openconnect' 'opensc' 'pcsclite' 'polkit' 'dbus' 'libsecret'
           'gnutls' 'libxml2' 'zlib' 'lz4' 'libp11-kit' 'nettle' 'gmp' 'openssl')
  provides=('gpclient' 'gpservice' 'gpauth')
  conflicts=('globalprotect-openconnect')

  cd "$_pkgname-$pkgver"
  make install DESTDIR="$pkgdir"
}
