#!/usr/bin/make -f

# Build the GUI too: this source emits both the backend package and the
# globalprotect-openconnect-dw-gui package (split via debian/*.install).
export INCLUDE_GUI = 1
export DISABLE_RUST_TOOLCHAIN = 0

export PATH := /usr/lib/rust-@RUST_VERSION@/bin:/usr/local/cargo/bin:$(PATH)

%:
	which cargo
	which rustc
	dh $@ --no-parallel
