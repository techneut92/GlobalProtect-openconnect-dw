# Maintainer: Dylan Westra <dylanwestra@gmail.com>

pkgname=@PKG_NAME@
pkgver=@VERSION@
pkgrel=@REVISION@
pkgdesc="GlobalProtect VPN backend (PKCS#11 fork), based on OpenConnect. Smart-card / SSO / certificate auth."
url="https://github.com/techneut92/GlobalProtect-openconnect-dw"
arch="x86_64 aarch64"
license="GPL-3.0-only"
depends="
	dbus
	gmp
	gnutls
	libxml2
	lz4
	nettle
	openconnect
	opensc
	openssl
	p11-kit
	pcsc-lite
	polkit
	zlib
	"
makedepends="
	autoconf
	automake
	cargo
	file
	gettext-dev
	gmp-dev
	gnutls-dev
	libtool
	libxml2-dev
	librsvg-dev
	lz4-dev
	make
	nettle-dev
	openssl-dev
	p11-kit-dev
	patch
	pkgconf
	webkit2gtk-4.1-dev
	zlib-dev
	"
subpackages="$pkgname-gui"
source="$pkgname-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgver"
options="!check"

build() {
	cd "$builddir"

	unset CFLAGS
	unset RUSTFLAGS

	make build INCLUDE_GUI=1 LIBXML2_STATIC="${LIBXML2_STATIC:-1}"
}

package() {
	cd "$builddir"

	# Backend only; the GUI lands in the -gui subpackage below.
	make install DESTDIR="$pkgdir" INCLUDE_GUI=0
}

gui() {
	pkgdesc="GlobalProtect VPN graphical client (Tauri)"
	depends="$pkgname webkit2gtk-4.1 libsecret"

	cd "$builddir"
	install -Dm755 target/release/gpgui "$subpkgdir/usr/bin/gpgui"
	install -Dm644 apps/gpgui/packaging/gpgui.desktop "$subpkgdir/usr/share/applications/gpgui.desktop"
	install -Dm644 apps/gpgui/icons/128x128.png "$subpkgdir/usr/share/icons/hicolor/128x128/apps/gpgui.png"
}

sha512sums="
@SHA512@  $pkgname-$pkgver.tar.gz
"
