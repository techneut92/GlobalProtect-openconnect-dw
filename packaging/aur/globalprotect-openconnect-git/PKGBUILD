# Maintainer: Dylan Westra <dylanwestra@gmail.com>

_pkgname_prefix=globalprotect-openconnect
pkgname="${_pkgname_prefix}-git"
pkgver=2.5.1.r1.g24f9bbb
pkgrel=3
pkgdesc="GlobalProtect VPN backend and CLI (gpservice/gpclient/gpauth), based on OpenConnect, with SSO and smart-card (PKCS#11) authentication."
arch=(x86_64 aarch64)
url="https://github.com/techneut92/GlobalProtect-openconnect-dw"
license=('GPL3')

makedepends=(git pkg-config 'openconnect>=8.20' file openssl cargo)
depends=(vpnc openssl libxml2 shared-mime-info desktop-file-utils)

conflicts=('globalprotect-openconnect')
provides=('globalprotect-openconnect' 'gpclient' 'gpservice' 'gpauth')

install=gp.install

source=("${_pkgname_prefix}::git+https://github.com/techneut92/GlobalProtect-openconnect-dw.git#branch=main")

sha256sums=("SKIP")

options=('!strip')

pkgver() {
  cd "${_pkgname_prefix}"

  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "${_pkgname_prefix}"
  git submodule update --init --recursive

  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  # Must unset the CFLAGS, otherwise the build fails on linking openssl, don't know why
  unset CFLAGS

  cd "${_pkgname_prefix}"
  cargo build --frozen --release
}

package() {
  cd "${_pkgname_prefix}"

  DESTDIR="$pkgdir" make install
}
