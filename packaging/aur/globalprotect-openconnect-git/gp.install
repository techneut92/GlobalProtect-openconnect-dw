post_install() {
    update-mime-database /usr/share/mime
    update-desktop-database -q
}

pre_upgrade() {
    rm -f /usr/bin/gpgui
}

post_upgrade() {
    update-mime-database /usr/share/mime
    update-desktop-database -q
}

post_remove() {
    rm -f /usr/bin/gpgui
    update-mime-database /usr/share/mime
    update-desktop-database -q
}
