{
  "$schema": "https://cdn.jsdelivr.net/gh/tauri-apps/tauri@tauri-v2.1.1/crates/tauri-cli/config.schema.json",
  "productName": "GP Client",
  "version": "1.2.0",
  "identifier": "io.github.techneut92.gpgui",
  "build": {
    "frontendDist": "ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "GP Client",
        "width": 460,
        "height": 822,
        "minWidth": 460,
        "minHeight": 822,
        "maxWidth": 460,
        "maxHeight": 822,
        "resizable": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
