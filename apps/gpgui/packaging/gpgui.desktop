[Desktop Entry]
Type=Application
Name=GlobalProtect
GenericName=VPN Client
Comment=Connect to GlobalProtect VPN (smart-card / certificate)
Exec=env WEBKIT_DISABLE_DMABUF_RENDERER=1 /usr/bin/gpgui
Icon=gpgui
Terminal=false
Categories=Network;Security;
Keywords=VPN;GlobalProtect;OpenConnect;PKCS11;
StartupNotify=true
# Window app-id / WM_CLASS the GUI advertises (the binary name). Lets the shell
# map the window to this entry (icon/title) and lets tiling compositors target
# it in a float rule.
StartupWMClass=gpgui
